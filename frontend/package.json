{
  "name": "rightnow-fitness",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "dev:api": "npm --prefix ./rightnow-api run start:dev",
    "db:up": "docker compose -f ./rightnow-api/docker-compose.yml up -d",
    "db:down": "docker compose -f ./rightnow-api/docker-compose.yml down",
    "db:logs": "docker compose -f ./rightnow-api/docker-compose.yml logs -f postgres",
    "db:push": "npm --prefix ./rightnow-api run prisma:push",
    "db:seed": "npm --prefix ./rightnow-api run prisma:seed",
    "db:init": "npm run db:push && npm run db:seed",
    "build": "vite build",
    "build:api": "npm --prefix ./rightnow-api run build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@types/three": "^0.182.0",
    "axios": "^1.13.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.7.0",
    "three": "^0.182.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
