# Backend local environment example.
# Copy to backend/.env only for local development.

DATABASE_URL=postgresql://postgres:change-me@localhost:5432/rightnow_fitness
JWT_SECRET=change-me
PORT=5000
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

STEPFUN_BASE_URL=https://api.stepfun.com/v1
STEPFUN_API_KEY=
STEPFUN_CHAT_MODEL=step-3.7-flash
INTENT_CLASSIFIER_VERSION=v2
INTENT_MODEL_FALLBACK_READ_ONLY=false
INTENT_MODEL_MIN_CONFIDENCE=0.80
# Local Demo only: fall back to the configured chat provider when OpenClaw is unavailable.
CHAT_DIRECT_FALLBACK=false

IMAGE_GEN_BASE_URL=
IMAGE_GEN_MODEL=gpt-image-2
IMAGE_GEN_API_KEY=

OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_GATEWAY_TOKEN=change-me
OPENCLAW_PROVISION_MODE=admin-http
OPENCLAW_ADMIN_URL=
OPENCLAW_ADMIN_TOKEN=change-me
OPENCLAW_ADMIN_TIMEOUT_MS=5000
OPENCLAW_USE_DB_HISTORY=true
OPENCLAW_DB_HISTORY_WINDOW=16
AGENT_SERVICE_TOKEN=change-me
INTERNAL_API_TOKEN=change-me
