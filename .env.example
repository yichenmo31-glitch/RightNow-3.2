# RightNow local/deployment environment example.
# Copy to .env and fill real values locally or on your server.
# Never commit real secrets.

POSTGRES_DB=rightnow_fitness
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://postgres:change-me@postgres:5432/rightnow_fitness

JWT_SECRET=change-me
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=change-me
ADMIN_SEED_NAME=RightNow Admin

CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Image generation providers
IMAGE_GEN_BASE_URL=
IMAGE_GEN_MODEL=gpt-image-2
IMAGE_GEN_API_KEY=
IMAGE_GEN_PROXY_URL=
IMAGE_GEN_FALLBACK_MODEL=

ARK_IMAGE_API_KEY=
ARK_IMAGE_BASE_URL=
ARK_IMAGE_MODEL=doubao-seedream-5-0-260128

LEGACY_IMAGE_GEN_API_KEY=
LEGACY_IMAGE_GEN_BASE_URL=
LEGACY_IMAGE_GEN_MODEL=gpt-image-2

MIRROR_IMAGE_API_KEY=
MIRROR_IMAGE_BASE_URL=
MIRROR_IMAGE_MODEL=gpt-image-2

# LLM providers
STEPFUN_BASE_URL=https://api.stepfun.com/v1
STEPFUN_API_KEY=
STEPFUN_CHAT_MODEL=step-3.7-flash

DEEPSEEK_BASE_URL=
DEEPSEEK_API_KEY=
DEEPSEEK_CHAT_MODEL=deepseek-chat

# OpenClaw / agent bridge
OPENCLAW_GATEWAY_TOKEN=change-me
AGENT_SERVICE_TOKEN=change-me
INTERNAL_API_TOKEN=change-me
OPENCLAW_PROVISION_MODE=verify

# Optional single-user bridge mode
SINGLE_USER_MODE=false
SINGLE_USER_ID=
SINGLE_USER_CHANNELS=
